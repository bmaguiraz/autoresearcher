{
  "experiment_id": "04-imagegen-nanobanana",
  "name": "Image Generation Prompt Optimization (Nano)",
  "description": "Short experiment to test per-issue parallelism. 2 cycle optimization for image gen prompts.",
  "version": "1.0.0",
  "cycles": 2,
  "parameters": {
    "model": "stable-diffusion",
    "optimization_strategy": "iterative_refinement"
  },
  "baseline_prompt": "A photo of a banana",
  "optimization_criteria": [
    "visual_quality",
    "prompt_clarity",
    "style_consistency",
    "composition"
  ]
}
